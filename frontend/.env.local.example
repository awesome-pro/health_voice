# HealthVoice frontend — environment configuration
#
# Copy this file to `.env.local` and adjust as needed:
#   cp .env.local.example .env.local
#
# WebSocket endpoint of the HealthVoice transcription backend.
# The frontend streams 16 kHz mono Int16 PCM binary frames here and renders
# the transcript messages the backend sends back.
#
# Default (used when this is unset): ws://localhost:8000/ws/transcribe
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/transcribe

# HTTP base URL of the HealthVoice backend, used for nurse voice enrollment
# (GET /enroll/status, POST /enroll, DELETE /enroll).
#
# Default (used when this is unset): http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
