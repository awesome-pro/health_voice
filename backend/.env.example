# HealthVoice backend — example secrets file.
# Copy to `.env` and fill in your own values:  cp .env.example .env

# --- Phase 4: SOAP note generation backend ---
# "openai" (default, hosted, one network call) or "ollama" (fully local, nothing
# leaves the machine). Flip to ollama for the 100% on-device pipeline.
# SOAP_BACKEND=openai

# OpenAI path. Key for the hosted SOAP note generation.
OPENAI_API_KEY=sk-...
# Optional model override (defaults to gpt-5.5).
# OPENAI_MODEL=gpt-5.5

# Ollama path (only used when SOAP_BACKEND=ollama). Model must be pulled already:
#   ollama pull qwen3:8b
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434

# Optional Hugging Face read token for the Phase 2b pyannote diarization
# refine pass (gated model). Leave blank to skip it.
HF_TOKEN=hf_...
